{
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "quietStartup": false,
  "enableSkillCommands": true,
  "sessionDir": ".pi/sessions",
  "compaction": {
    "enabled": true,
    "reserveTokens": 24000,
    "keepRecentTokens": 28000
